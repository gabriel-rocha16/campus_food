<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Campus Food" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Campus Food">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

<body>
    <nav style="background: #2c3e50; padding: 15px; display: flex; gap: 20px; align-items: center;">
      <strong style="color: white; font-size: 1.2rem; margin-right: 20px;">CAMPUS FOOD 3.0</strong>
      <%= link_to "Produtos", produtos_path, style: "color: white; text-decoration: none;" %>
      <%= link_to "Clientes", clientes_path, style: "color: white; text-decoration: none;" %>
      <%= link_to "Vendas", vendas_path, style: "color: white; text-decoration: none;" %>
      <%# Se você criou o de Funcionários, adicione aqui %>
      <%= link_to "Funcionários", funcionarios_path, style: "color: white; text-decoration: none;" if defined?(funcionarios_path) %>
    </nav>

    <div style="background: #ecf0f1; padding: 10px; text-align: right; border-bottom: 1px solid #bdc3c7;">
      <% if user_signed_in? %>
        <span>Logado como: <strong><%= current_user.email %></strong></span>
        <%= link_to "Sair", destroy_user_session_path, data: { turbo_method: :delete }, style: "margin-left: 15px; color: #e74c3c; font-weight: bold;" %>
      <% else %>
        <%= link_to "Entrar", new_user_session_path, style: "margin-right: 10px;" %>
        <%= link_to "Registrar", new_user_registration_path %>
      <% end %>
    </div>

    <p style="color: green; text-align: center;"><%= notice %></p>
    <p style="color: red; text-align: center;"><%= alert %></p>

    <main style="padding: 20px; max-width: 1200px; margin: 0 auto;">
      <%= yield %>
    </main>
  </body>
</html>
