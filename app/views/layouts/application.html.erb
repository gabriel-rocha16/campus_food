<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Campus Food" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Campus Food">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      /* Estilos para manter o Footer no fundo (Sticky Footer) */
      html, body {
        height: 100%;
        margin: 0;
      }

      body {
        display: flex;
        flex-direction: column;
        font-family: sans-serif;
      }

      .main-content {
        flex: 1 0 auto; /* Faz o conteúdo principal crescer e empurrar o footer */
        padding: 20px;
      }

      /* Estilização do Footer */
      .main-footer {
        flex-shrink: 0; /* Impede o footer de encolher */
        background-color: #2c3e50;
        color: white;
        padding: 20px 0;
        margin-top: 40px;
        border-top: 4px solid #e67e22; /* Detalhe em laranja para combinar com o logo */
      }

      .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 20px;
      }

      .footer-info p {
        margin: 5px 0;
        font-size: 14px;
        opacity: 0.8;
      }

      .footer-brand {
        font-weight: bold;
        letter-spacing: 1px;
      }
    </style>
  </head>

  <body>

    <header class="topbar">
      <div class="topbar-container">

        <div class="logo">
          <span class="campus" style="color: #2c3e50; font-weight: bold;">CAMPUS</span>
          <span class="food" style="color: #e67e22; font-weight: bold;">FOOD</span>
        </div>

        <nav class="menu">
          <%= link_to "Clientes", clientes_path,
            class: ("active" if current_page?(clientes_path)) %>

          <%= link_to "Funcionários", funcionarios_path,
            class: ("active" if defined?(funcionarios_path) && current_page?(funcionarios_path)) %>

          <%= link_to "Produtos", produtos_path,
             class: ("active" if current_page?(produtos_path)) %>

          <%= link_to "Vendas", vendas_path,
            class: ("active" if current_page?(vendas_path)) %>

          <%= link_to "Relatórios", "#",
            class: ("active" if current_page?("#")) %>
        </nav>

        <div class="user-info">
          <% if user_signed_in? %>
            <span>Logado como: <strong><%= current_user.email %></strong></span>
            <%= link_to "Sair", destroy_user_session_path, data: { turbo_method: :delete }, class: "logout", style: "margin-left: 10px; color: #e74c3c;" %>
          <% else %>
            <%= link_to "Entrar", new_user_session_path, class: "auth-link" %>
            <%= link_to "Registrar", new_user_registration_path, class: "auth-link" %>
          <% end %>
        </div>

      </div>
    </header>

    <main class="main-content">
      <% if notice %>
        <p class="flash notice" style="background: #d4edda; color: #155724; padding: 10px; border-radius: 5px;"><%= notice %></p>
      <% end %>

      <% if alert %>
        <p class="flash alert" style="background: #f8d7da; color: #721c24; padding: 10px; border-radius: 5px;"><%= alert %></p>
      <% end %>

      <%= yield %>
    </main>

    <footer class="main-footer">
      <div class="footer-container">
        <div class="footer-info">
          <p class="footer-brand">CAMPUS FOOD SYSTEM</p>
          <p>&copy; <%= Time.now.year %> - Todos os direitos reservados.</p>
        </div>
        
        <div class="footer-info" style="text-align: right;">
          <p>Ambiente: <strong><%= Rails.env.capitalize %></strong></p>
          <% if user_signed_in? %>
            <p>Sessão ativa: <%= current_user.email %></p>
          <% end %>
        </div>
      </div>
    </footer>

  </body>
</html>