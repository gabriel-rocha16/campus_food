<div class="nested-fields item-form-row" style="display: flex; gap: 15px; align-items: flex-end; background: #f9f9f9; padding: 15px; border-radius: 5px; margin-bottom: 10px; border: 1px solid #ddd;">
  <div style="flex: 2;">
    <%= f.label :produto_id, "Produto" %>
    <%# O segredo está no data-action e no data-venda-target %>
    <%= f.collection_select :produto_id, Produto.all, :id, :nome, 
        { prompt: "Selecione o produto..." }, 
        { data: { action: "change->venda#updatePrice", venda_target: "produtoSelect" }, 
          style: "width: 100%; padding: 5px;" } %>
  </div>

  <div style="flex: 1;">
    <%= f.label :quantidade, "Qtd" %>
    <%= f.number_field :quantidade, 
        step: 1, min: 1, 
        data: { action: "input->venda#calculateTotal" },
        style: "width: 100%; padding: 5px;" %>
  </div>

  <div style="flex: 1;">
    <%= f.label :preco_unitario, "Preço Unit. (R$)" %>
    <%# Este target DEVE ser unitPrice para o JS encontrar %>
    <%= f.text_field :preco_unitario, 
        data: { venda_target: "unitPrice" },
        readonly: true,
        style: "width: 100%; padding: 5px; background: #eee;" %>
  </div>
</div>